# Financial Settlement System Configuration
# Copy to config.env and modify as needed.
# Place next to the executable in production deployments.

# Server port (default 8770)
# FINANCE_PORT=8770

# Server bind address (default 127.0.0.1)
# FINANCE_HOST=127.0.0.1

# Disable HTTPS (default: HTTPS enabled with auto-generated self-signed certificate)
# Set to true to use plain HTTP if self-signed cert causes issues in your environment
# FINANCE_NO_SSL=false

# Database path (default data/settlement.db)
# Use absolute path or path relative to the executable
# DB_PATH=data/settlement.db

# Backup encryption password (optional)
# Set a password → PBKDF2-HMAC-SHA256 (100K) derived key + AES-256-CBC encrypted, portable across machines
# Leave empty → plain backup (no encryption)
# BACKUP_ENCRYPTION_PASSWORD=your-password-here

# Login password (set automatically on first launch, do not manually edit)
# FINANCE_PASSWORD_HASH=

# Update check URL (optional)
# Deploy version.json to this URL for automatic update checks
# UPDATE_URL=https://example.com/updates/

# CORS origins (optional, comma-separated)
# Default allows only localhost dev addresses
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# QuickSDK integration (optional — leave empty to disable the feature)
# Obtain openId and openKey from QuickSDK support
# Multi-key format (recommended): JSON array of {label, openId, openKey, baseUrl?}
# QK_KEYS=[{"label":"主账号","openId":"xxx","openKey":"xxx","baseUrl":"https://www.quicksdk.com"}]
QK_KEYS=
# Legacy single-key (used as fallback if QK_KEYS not set)
QK_OPEN_ID=
QK_OPEN_KEY=
QK_BASE_URL=https://www.quicksdk.com
# Product-to-game mapping for batch import: JSON array of {productCode, game_id}
# QK_PRODUCT_MAP=[{"productCode":"222033...","game_id":"ny10192"}]
QK_PRODUCT_MAP=
